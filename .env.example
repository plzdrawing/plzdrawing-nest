# ------------------------------------------------------------------
# Example environment file
# Copy this file to `.env` and replace all `YOUR_...` placeholders.
# ------------------------------------------------------------------

# Basic
PORT=3000
NODE_ENV=development

# Database
DB_HOST=YOUR_DB_HOST
DB_PORT=3306
DB_USERNAME=YOUR_DB_USERNAME
DB_PASSWORD=YOUR_DB_PASSWORD
DB_DATABASE=YOUR_DB_DATABASE
# local 개발에서는 true도 가능, 스테이징/운영은 false 권장
DB_SYNCHRONIZE=true
DB_LOGGING=true

# Redis
REDIS_HOST=YOUR_REDIS_HOST
REDIS_PORT=6379

# Mail
MAIL_HOST=YOUR_SMTP_HOST
MAIL_PORT=587
MAIL_USERNAME=YOUR_MAIL_USERNAME
MAIL_PASSWORD=YOUR_MAIL_PASSWORD

# Auth
# Long random secret string
SECRET_KEY=YOUR_SECRET_KEY
ACCESS_EXPIRATION=3600000
AUTH_CODE_EXPIRATION=180000
MEMBER_REDIRECT_URL=YOUR_MEMBER_REDIRECT_URL
OAUTH_REDIRECT_URL=gree://oauth/callback

# Google OAuth
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=YOUR_GOOGLE_CALLBACK_URL

# Kakao OAuth
KAKAO_CLIENT_ID=YOUR_KAKAO_CLIENT_ID
KAKAO_CLIENT_SECRET=YOUR_KAKAO_CLIENT_SECRET
KAKAO_REDIRECT_URI=YOUR_KAKAO_REDIRECT_URI

# AWS
AWS_ACCESS_KEY=YOUR_AWS_ACCESS_KEY
AWS_SECRET_KEY=YOUR_AWS_SECRET_KEY
BUCKET_REGION=YOUR_BUCKET_REGION
BUCKET_NAME=YOUR_BUCKET_NAME

# Firebase
# Relative path from project root
FIREBASE_CONFIG_PATH=./firebase-service-account.json

# Toss Payments
# Example: test_sk_xxxxxxxxxxxxxxxxx
TOSS_PAYMENTS_SECRET_KEY=YOUR_TOSS_PAYMENTS_SECRET_KEY
TOSS_PAYMENTS_API_BASE_URL=https://api.tosspayments.com

# Withdraw
# Policy examples
WITHDRAW_MINIMUM_COIN_AMOUNT=10
WITHDRAW_COIN_UNIT=10
WITHDRAW_CASH_PER_COIN=100
WITHDRAW_FLAT_FEE_AMOUNT=0
WITHDRAW_ACCOUNT_SECRET=YOUR_WITHDRAW_ACCOUNT_SECRET

# App Info
APP_VERSION=0.0.1
MIN_SUPPORTED_VERSION=0.0.1
SUPPORT_EMAIL=YOUR_SUPPORT_EMAIL
SUPPORT_HOURS=YOUR_SUPPORT_HOURS
PRIVACY_POLICY_URL=https://example.com/privacy-policy

# Seed
# false면 기본 시드를 비활성화합니다.
SEED_DEFAULT_DATA=true
# 약관 시드에 사용할 관리자 회원 ID
SEED_ADMIN_ID=1
